# =========================================================================
# ollama-mcp-server — environment variables
#
# Copy this file to ".env" and adjust. NEVER commit ".env" (it is gitignored).
# Quarkus auto-loads ".env" from the project root in dev/test, so the remote
# host is configured here rather than hard-coded anywhere.
#
#   cp .env.example .env
# =========================================================================

# --- Remote Ollama host ---------------------------------------------------
# Ollama runs on a SEPARATE machine so the dev laptop is not overloaded.
# The remote box must bind to all interfaces (OLLAMA_HOST=0.0.0.0:11434) or
# the LAN can't reach it — see the README "Remote Ollama" section.
OLLAMA_BASE_URL=http://192.168.1.5:11434

# Default model used when a tool's "model" argument is left blank.
OLLAMA_DEFAULT_MODEL=qwen3:30b

# Read timeout for Ollama calls (remote + 30B model => be generous).
# OLLAMA_TIMEOUT=120s

# --- Server -----------------------------------------------------------------
# HTTP port this MCP server listens on. Defaults to 8085 (not 8080) so it can
# run alongside other apps / Postman collections that use 8080.
# MCP_HTTP_PORT=8085

# --- Logging --------------------------------------------------------------
# Max characters of a tool argument logged per line before truncation.
# LOG_MAX_BODY=2000
