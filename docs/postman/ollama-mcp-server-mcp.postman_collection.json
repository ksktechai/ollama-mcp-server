              "function mcpResult(){var b=pm.response.text().replace(/^\\uFEFF/,'').trim();if(b.charAt(0)!=='{'&&b.indexOf('data:')!==-1){b=b.split(/\\r?\\n/).filter(function(l){return l.indexOf('data:')===0;}).map(function(l){return l.slice(5).trim();}).join('');}return JSON.parse(b);}",
              "",
              "// The server parses defensively: bad input comes back as a readable error payload,",
              "// returned as a normal tool result (HTTP 200), never a 500.",
              "pm.test('transport returns 200 (no server error)', function () { pm.response.to.have.status(200); });",
              "var rpc = mcpResult();",
              "var text = rpc.result.content[0].text;",
              "pm.test('payload names the parsing error', function () {",
              "  pm.expect(text).to.include('messagesJson must be a JSON array');",
              "});"
            ]
          }
        }
