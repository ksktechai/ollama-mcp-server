              "",
              "// Runs the server's configured default collection via Newman. To also get a local-LLM",
              "// summary, set arguments to {\"analyze\":true,\"analysisModel\":\"qwen3:8b\"} and read result.analysis.",
              "pm.test('transport returns 200', function () { pm.response.to.have.status(200); });",
              "var o = JSON.parse(mcpResult().result.content[0].text);",
              "pm.test('run_postman_collection returned a tool result', function () { pm.expect(o).to.be.an('object'); });",
              "if (o.error) {",
              "  // Newman/npx missing or target API down — surfaced as a readable payload, not a 500.",
              "  console.log('run_postman_collection could not run:', o.error, o.detail || '');",
              "} else {",
              "  pm.test('result has structured run fields', function () {",
              "    pm.expect(o).to.have.property('passed');",
              "    pm.expect(o).to.have.property('stats');",
              "    pm.expect(o.requests, 'per-request breakdown').to.be.an('array');",
              "  });",
              "  console.log('collection run:', o.passed ? 'PASS' : 'FAIL', '| assertions', JSON.stringify(o.stats && o.stats.assertions));",
              "}"
            ],
            "type": "text/javascript",
            "packages": {},
            "requests": {}
          }
        }
